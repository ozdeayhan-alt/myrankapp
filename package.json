{
  "name": "myrankapp",
  "version": "1.0.0",
  "description": "Express API server with Firebase Admin SDK integration",
  "main": "index.js",
  "scripts": {
    "start": "node index.js",
    "dev": "node --watch index.js",
    "test": "node --test src/lib/rateLimit.test.js src/lib/redis.test.js src/lib/segmentFilters.test.js src/features/feed/feedCache.test.js src/features/feed/feedContentType.test.js src/features/bots/segmentBotPersonas.test.js src/features/messages/fetchInbox.test.js src/features/posts/createPost.test.js src/features/ranking/voteErrors.test.js src/features/duel/clampDuelDelta.test.js scripts/rebuild-rankings.segmentBots.test.js",
    "check": "npm test && node --check index.js",
    "test-push": "node scripts/test-expo-push.js",
    "prune-push-tokens": "node scripts/prune-push-tokens.js",
    "health-monitor": "node scripts/health-monitor.js",
    "setup-faz1": "bash deploy/setup-faz1.sh",
    "ensure-authorized-domains": "node scripts/ensure-authorized-domains.js",
    "rebuild-rankings": "node scripts/rebuild-rankings.js",
    "seed-bots": "node scripts/seed-bots.js",
    "seed-character-bots": "node scripts/seed-character-bots.js",
    "seed-bot-stories": "node scripts/seed-bot-stories.js",
    "run-bot-jobs": "node scripts/run-bot-jobs.js",
    "backfill-display-name-lower": "node scripts/backfill-display-name-lower.js",
    "backfill-photo-urls": "node scripts/backfill-photo-urls.js",
    "repair-profile-photos": "node scripts/repair-profile-photos.js",
    "backfill-user-feeds": "node scripts/backfill-user-feeds.js",
    "backfill-media-dimensions": "node scripts/backfill-media-dimensions.js",
    "audit-user-feeds": "node scripts/audit-user-feeds.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
